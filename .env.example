# EngramAtlas Local Server Settings

# Express Server Port (Default is 3000)
PORT=3000

# Google Gen AI SDK API Key
# 必須。ローカルでの動作検証およびエージェントの推論に使用します。
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model for Content Generation (e.g. gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Gemini Embedding Model for Vector Generation
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# MongoDB Atlas Connection String
# 必須。engramsコレクションを作成・更新するためのURI。
# 例: mongodb+srv://<username>:<password>@cluster.mongodb.net/engram_atlas?retryWrites=true&w=majority
MONGODB_URI=mongodb_connection_string_here
